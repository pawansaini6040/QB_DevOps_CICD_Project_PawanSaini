name: CI/CD Pipeline

on:
  workflow_dispatch:

env:
  IMAGE_NAME: doc201/flask-app

jobs:
  build-deploy:
    runs-on: self-hosted   # Change to self-hosted if K8s API is private

    steps:

    - name: Checkout Code
      uses: actions/checkout@v4

    - name: Set Image Tag
      run: echo "TAG=${GITHUB_RUN_NUMBER}" >> $GITHUB_ENV

    - name: Login to DockerHub
      uses: docker/login-action@v3
      with:
        username: ${{ secrets.DOCKER_USERNAME }}
        password: ${{ secrets.DOCKER_PASSWORD }}

    - name: Build Docker Image
      run: |
        docker build -t $IMAGE_NAME:$TAG .
        docker tag $IMAGE_NAME:$TAG $IMAGE_NAME:latest

    - name: Push Docker Image
      run: |
        docker push $IMAGE_NAME:$TAG
        docker push $IMAGE_NAME:latest

    - name: Setup Kubeconfig
      run: |
        mkdir -p ~/.kube
        echo "${{ secrets.KUBECONFIG_DATA }}" | base64 -d > ~/.kube/config

    - name: Verify Cluster Access
      run: |
        kubectl cluster-info
        kubectl get nodes

    - name: Deploy Application
      run: |
        if kubectl get deployment flask-deployment >/dev/null 2>&1; then
          echo "Deployment exists. Updating image..."

          kubectl set image deployment/flask-deployment \
          flask=$IMAGE_NAME:$TAG

        else
          echo "Deployment does not exist. Creating deployment..."

          kubectl apply -f deployment.yaml
          kubectl apply -f service.yaml

          kubectl set image deployment/flask-deployment \
          flask=$IMAGE_NAME:$TAG
        fi

    - name: Wait For Rollout
      run: |
        kubectl rollout status deployment/flask-deployment --timeout=300s

    - name: Verify Deployment
      run: |
        kubectl get deployment
        kubectl get pods -o wide
        kubectl get svc
